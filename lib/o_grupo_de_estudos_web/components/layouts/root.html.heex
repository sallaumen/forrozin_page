<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta
      name="description"
      content={
        assigns[:meta_description] ||
          "Uma wiki de forró construída pela comunidade. Mais de 150 passos documentados, conexões entre eles, sequências e diário de treino. Tudo aberto e gratuito."
      }
    />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="O Grupo de Estudos" />
    <meta
      property="og:title"
      content={assigns[:meta_title] || "O Grupo de Estudos | Wiki de Forró"}
    />
    <meta
      property="og:description"
      content={
        assigns[:meta_description] ||
          "Uma wiki de forró construída pela comunidade. Mais de 150 passos documentados, conexões, sequências e diário de treino. Tudo gratuito."
      }
    />
    <meta
      property="og:image"
      content={assigns[:meta_image] || "https://ogrupodeestudos.com.br/icons/icon-512.png"}
    />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:url" content="https://ogrupodeestudos.com.br" />
    <meta property="og:locale" content="pt_BR" />
    <meta name="twitter:card" content="summary" />
    <meta
      name="twitter:title"
      content={assigns[:meta_title] || "O Grupo de Estudos"}
    />
    <meta
      name="twitter:description"
      content={
        assigns[:meta_description] ||
          "Wiki de forró construída pela comunidade. Tudo aberto e gratuito."
      }
    />
    <.live_title default="O Grupo de Estudos" suffix=" · O Grupo de Estudos">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <link
      rel="preload"
      href="/fonts/Inter-Variable.woff2"
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#1a0e05" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Grupo de Estudos" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icons/icon-192.png" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <script phx-track-static type="module" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body>
    <.flash kind={:info} flash={@flash} />
    <.flash kind={:error} flash={@flash} />
    {@inner_content}
  </body>
</html>
