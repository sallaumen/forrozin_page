<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <meta
      name="description"
      content="Acervo colaborativo de passos de forró roots com mais de 150 passos catalogados, conexões entre eles e sequências criadas pela comunidade."
    />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="O Grupo de Estudos" />
    <meta property="og:title" content="O Grupo de Estudos | Wiki de Forró Roots" />
    <meta
      property="og:description"
      content="Acervo colaborativo com mais de 100 passos de forró catalogados, mapa de conexões entre passos e sequências criadas pela comunidade. Feito por dançarinos, pra dançarinos."
    />
    <meta property="og:image" content="https://ogrupodeestudos.com.br/icons/icon-512.png" />
    <meta property="og:image:width" content="512" />
    <meta property="og:image:height" content="512" />
    <meta property="og:url" content="https://ogrupodeestudos.com.br" />
    <meta property="og:locale" content="pt_BR" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content="O Grupo de Estudos" />
    <meta name="twitter:description" content="Wiki de forró roots construída pela comunidade." />
    <.live_title default="O Grupo de Estudos" suffix=" · O Grupo de Estudos">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <link rel="preload" href="/fonts/Inter-Variable.woff2" as="font" type="font/woff2" crossorigin />
    <link rel="manifest" href="/manifest.json" />
    <meta name="theme-color" content="#1a0e05" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="default" />
    <meta name="apple-mobile-web-app-title" content="Grupo de Estudos" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icons/icon-192.png" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <script phx-track-static type="module" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body>
    {@inner_content}
  </body>
</html>
